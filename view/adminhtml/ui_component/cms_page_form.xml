<?xml version="1.0" encoding="UTF-8"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <fieldset name="clusterify_chatbot_guide_fieldset" sortOrder="150">
        <settings>
            <label translate="true">Clusterify.AI - ChatBot Guide</label>
            <collapsible>true</collapsible>
            <opened>false</opened>
        </settings>
        <field name="clusterify_chatbot_guide" formElement="textarea" sortOrder="10">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">page</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Additional information for Chatbot</label>
                <dataScope>clusterify_chatbot_guide</dataScope>
                <notice translate="true">This hidden field is not visible on the frontend page. It uses a specific ID that the chatbot utilizes to deliver more accurate and helpful responses and guidance to the customer.</notice>
            </settings>
        </field>
    </fieldset>
</form>
